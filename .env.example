# Server
PORT=3000
NODE_ENV=development

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=project42-governance
KAFKA_GROUP_ID=governance-group

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_password

# Gemini (for Refactoring Agent LLM)
GEMINI_API_KEY=your_gemini_api_key

# Prometheus
METRICS_PORT=9090

# Governance
SCAN_INTERVAL_MS=60000
SECURITY_SCAN_INTERVAL_MS=300000
